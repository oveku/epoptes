# --- Required (no defaults — the stack will refuse to start without these) ---
# Strong, unique values for production. Examples below are PLACEHOLDERS.
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_to_a_strong_password
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_password

# --- Optional (sensible defaults exist in compose) ---
# Public hostname or IP that the Grafana UI will be reachable at.
# Used for GF_SERVER_ROOT_URL in docker-compose.prod.yml. Use the LAN address
# of the host running Epoptes, or a domain name behind a reverse proxy.
EPOPTES_HOST=localhost

# Container image tags (only needed for docker-compose.prod.yml).
EPOPTES_API_IMAGE=epoptes-api:latest
EPOPTES_WEB_IMAGE=epoptes-web:latest

# Database
POSTGRES_USER=epoptes
POSTGRES_DB=epoptes

# Port mappings (host port : container port). Override to avoid conflicts.
EPOPTES_OTLP_GRPC_PORT=4317
EPOPTES_OTLP_HTTP_PORT=4318
EPOPTES_GRAFANA_PORT=3030
EPOPTES_PROMETHEUS_PORT=9190
EPOPTES_TEMPO_PORT=3320
EPOPTES_API_PORT=8180
EPOPTES_WEB_PORT=5174
EPOPTES_POSTGRES_PORT=15432
