{
  "annotations": { "list": [] },
  "description": "Estimated GitHub Copilot spend in USD and AI Credits, derived from emitted token metrics multiplied by per-model pricing (see prometheus/rules/copilot-pricing.yml). Rates updated from docs.github.com/en/copilot/reference/copilot-billing/models-and-pricing.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total Spend",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\"}[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Input Spend",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\"}[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Output Spend",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "1 AI Credit = $0.01 USD. This is the equivalent credit consumption under usage-based billing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "100 * sum(sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "AI Credits Consumed",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Spend rate per hour, broken down by model. Calculated from token rate and per-model pricing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "USD / hour",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "3600 * sum by (gen_ai_response_model) (sum by (gen_ai_response_model, gen_ai_token_type) (rate(epoptes_gen_ai_client_token_usage_sum[$__rate_interval])) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "legendFormat": "{{gen_ai_response_model}}",
          "refId": "A"
        }
      ],
      "title": "Spend Rate by Model (USD/hour)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Share of total spend in the selected range, by input vs output token type.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 5 },
      "id": 6,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (gen_ai_token_type) (sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "instant": true,
          "legendFormat": "{{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "title": "Spend Split: Input vs Output",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Top models ranked by total spend in the selected range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sizing": "manual",
        "minVizHeight": 16,
        "minVizWidth": 0,
        "valueMode": "color"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "topk(10, sum by (gen_ai_response_model) (sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6)",
          "instant": true,
          "legendFormat": "{{gen_ai_response_model}}",
          "refId": "A"
        }
      ],
      "title": "Top Models by Spend",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-model breakdown of input tokens, output tokens, and total spend over the selected range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Spend (USD)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Input tokens" },
            "properties": [{ "id": "unit", "value": "short" }]
          },
          {
            "matcher": { "id": "byName", "options": "Output tokens" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": true },
        "showHeader": true,
        "sortBy": [{ "displayName": "Spend (USD)", "desc": true }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (gen_ai_response_model) (increase(epoptes_gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\"}[$__range] @ end()))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (gen_ai_response_model) (increase(epoptes_gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\"}[$__range] @ end()))",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (gen_ai_response_model) (sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) * on (gen_ai_response_model, gen_ai_token_type) group_left epoptes_model_price_usd_per_million_tokens) / 1e6",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "title": "Spend by Model",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "gen_ai_response_model", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true },
            "indexByName": {},
            "renameByName": {
              "gen_ai_response_model": "Model",
              "Value #A": "Input tokens",
              "Value #B": "Output tokens",
              "Value #C": "Spend (USD)"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Tokens consumed by models not present in prometheus/rules/copilot-pricing.yml. A non-zero value means the cost dashboard is undercounting -- add the missing model(s) to the pricing rules.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 23 },
      "id": 9,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) unless on (gen_ai_response_model, gen_ai_token_type) epoptes_model_price_usd_per_million_tokens)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Unpriced Tokens (models missing from pricing rules)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Model names emitting tokens that are NOT covered by the pricing rules. Add these to prometheus/rules/copilot-pricing.yml.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 23 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Tokens", "desc": true }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (gen_ai_response_model, gen_ai_token_type) (increase(epoptes_gen_ai_client_token_usage_sum[$__range] @ end())) unless on (gen_ai_response_model, gen_ai_token_type) epoptes_model_price_usd_per_million_tokens",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Unpriced Models",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": {},
            "renameByName": {
              "gen_ai_response_model": "Model",
              "gen_ai_token_type": "Token type",
              "Value": "Tokens"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["epoptes", "copilot", "cost", "billing"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
